# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
htmlcov/

# Virtual environment (large; recreate with `make install`)
.venv/
.venv-gpu/
venv/
env/

# CosyVoice source checkout + downloaded model (installed via scripts/install_cosyvoice.sh)
third_party/

# Pipeline work dirs, model outputs, logs (regenerate at runtime)
.work/
*.log

# Generated fixtures (recreate with `make fixture`)
tests/fixtures/*.mp4
tests/fixtures/*.wav

# Secrets — never commit
.env
*.env
!config/*.example.yaml

# Local per-run config (contains user-specific paths); keep the template tracked
config/job.yaml

# OS / editor
.DS_Store
.idea/
.vscode/
